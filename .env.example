# Host directory for persistent data (jobs, database, etc.)
# This path on your host machine is mounted into the container.
METAGOMICS_DATA_DIR=./_data

# Number of CPU threads available for compute-intensive tasks (e.g. DIAMOND).
METAGOMICS_THREADS=4

# Annotated databases for homology search.
# Format: JSON array of objects with "name", "description", "path", and optional "annotations" keys.
# "path" is the .dmnd file relative to the databases mount point inside the container (/databases).
# "annotations" is the companion .annotations.db SQLite file (built by metagomics2-build-annotations).
# Example: [{"name":"SwissProt 2024_01","description":"UniProt SwissProt","path":"uniprot_sprot.dmnd","annotations":"uniprot_sprot.annotations.db"}]
METAGOMICS_DATABASES=[]

# Host directory containing DIAMOND-formatted annotated databases (.dmnd files).
# This is mounted read-only into the container at /databases.
METAGOMICS_DATABASES_DIR=./_databases

# Admin password for the /admin dashboard
METAGOMICS_ADMIN_PASSWORD=changeme

# Maximum upload size in megabytes for FASTA and peptide files.
# Uploads exceeding this limit are rejected with a 413 error.
# Default: 1024 (1 GB)
METAGOMICS_MAX_UPLOAD_MB=1024

# Whether to delete inputs/ and work/ directories after a job completes.
# Set to "false" to keep intermediate files for debugging.
METAGOMICS_CLEANUP_ON_SUCCESS=true
METAGOMICS_CLEANUP_ON_FAILURE=true

# --- Email Notifications (optional) ---
# If SMTP_HOST is set, users can optionally provide an email address when
# submitting a job. A notification will be sent when the job completes or fails.
# Leave SMTP_HOST empty to disable email notifications entirely.

# SMTP server hostname (e.g. smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=

# SMTP server port (587 for STARTTLS, 465 for SSL — currently uses STARTTLS)
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USERNAME=
SMTP_PASSWORD=

# Sender address shown in the "From" field of notification emails.
# Falls back to SMTP_USERNAME if not set.
SMTP_FROM=

# Public base URL of this Metagomics 2 instance (e.g. https://metagomics.example.com).
# Used to generate clickable job links in notification emails.
# Leave empty if you don't want links in emails.
SITE_URL=
