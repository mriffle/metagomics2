# ---------------------------------------------------------------------------
# Metagomics 2 — Environment Configuration
# ---------------------------------------------------------------------------
# This file contains simple scalar settings and paths.  Structured data such
# as database definitions belong in JSON config files (see config/ directory).
# Copy this file to .env and edit to match your setup.
# ---------------------------------------------------------------------------

# --- Filesystem Paths ---

# Host directory for persistent data (jobs, SQLite database, etc.)
# Mounted into the container at /data.
METAGOMICS_DATA_DIR=./_data

# Host directory containing DIAMOND-formatted annotated databases (.dmnd files).
# Mounted read-only into the container at /databases.
METAGOMICS_DATABASES_DIR=./_databases

# Directory containing JSON config files (databases.json, server.json).
# Mounted into the container at /config.
METAGOMICS_CONFIG_DIR=./config

# --- Runtime Settings ---

# Number of CPU threads for compute-intensive tasks (e.g. DIAMOND).
METAGOMICS_THREADS=4

# Admin password for the /admin dashboard.
METAGOMICS_ADMIN_PASSWORD=changeme

# Maximum upload size in megabytes for FASTA and peptide files.
# Uploads exceeding this limit are rejected with a 413 error.
METAGOMICS_MAX_UPLOAD_MB=1024

# Whether to delete inputs/ and work/ directories after a job completes.
# Set to "false" to keep intermediate files for debugging.
METAGOMICS_CLEANUP_ON_SUCCESS=true
METAGOMICS_CLEANUP_ON_FAILURE=true

# --- Email Notifications (optional) ---
# If SMTP_HOST is set, users can optionally provide an email address when
# submitting a job.  A notification is sent when the job completes or fails.
# Leave SMTP_HOST empty to disable email notifications entirely.

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Sender address shown in the "From" field.  Falls back to SMTP_USERNAME.
SMTP_FROM=

# Public base URL of this instance (e.g. https://metagomics.example.com).
# Used to build clickable job links in notification emails.
SITE_URL=
